# =====================================================
# 🚀 WHATSAPP INTEGRATION - VARIABLES D'ENVIRONNEMENT
# =====================================================
# Copiez ce contenu dans votre fichier .env

# Choisir le service WhatsApp à utiliser
# Options: twilio | meta | web (défaut: twilio)
WHATSAPP_SERVICE=twilio

# =====================================================
# 🟢 CONFIGURATION TWILIO
# =====================================================
# Obtenez ces infos sur: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+1415223456789

# =====================================================
# 🟢 CONFIGURATION META WHATSAPP BUSINESS API
# =====================================================
# Obtenez ces infos sur: https://developers.facebook.com/apps
META_PHONE_NUMBER_ID=104320205435435
META_WHATSAPP_ACCESS_TOKEN=EAAbxxxxxxxxxxxxxxxxxxxxx

# =====================================================
# 🟢 CONFIGURATION WHATSAPP WEB (Gratuit)
# =====================================================
# URL de votre serveur WhatsApp Web local
WHATSAPP_API_URL=http://localhost:3001

# =====================================================
# 🟢 NUMÉRO D'ADMINISTRATION
# =====================================================
# Le numéro WhatsApp où recevoir les notifications de commande
# Format: +237 (code pays) + 6 premiers chiffres du numéro
ADMIN_WHATSAPP_NUMBER=+237690316394

# =====================================================
# 🟢 NUMÉRO SECONDAIRE (Optionnel)
# =====================================================
# Pour envoyer à plusieurs numéros d'admin
SECONDARY_ADMIN_NUMBER=+237600000000

# =====================================================
# 🟢 AUTRES SERVICES (Existants)
# =====================================================
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

DATABASE_URL=your_mongodb_url
JWT_SECRET=your_jwt_secret

CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

STRIPE_SECRET_KEY=sk_test_xxxxx
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx
